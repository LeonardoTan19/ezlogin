{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ezlogin",
  "version": "1.1.0",
  "identifier": "com.leonardo.ezlogin",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ezlogin",
        "width": 440,
        "height": 620,
        "minWidth": 400,
        "maxWidth": 560,
        "minHeight": 560,
        "maxHeight": 760,
        "decorations": false,
        "transparent": true, 
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
